# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados
DB_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# Autenticacao
JWT_SECRET=sua_chave_jwt_aqui
JWT_EXPIRES=15m
REFRESH_TOKEN_SECRET=sua_chave_refresh_token_aqui
REFRESH_TOKEN_EXPIRES_DAYS=15

# Cookies
COOKIE_SECURE=false

# CORS / Frontend
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email
RESEND_API_KEY=sua_chave_resend_aqui
EMAIL_FROM=My GManager <noreply@seudominio.com>

# Keepalive
KEEPALIVE_SECRET=sua_chave_keepalive_aqui